{
  "mcpServers": {
    "uptime": {
      "command": "uptime-mcp",
      "args": [
        "--transport",
        "stdio"
      ],
      "env": {
        "UPTIME_URL": "${UPTIME_URL:-http://localhost:3001}",
        "UPTIME_TOKEN": "${UPTIME_TOKEN}",
        "MONITORSTOOL": "${ MONITORSTOOL:-True }",
        "STATUSTOOL": "${ STATUSTOOL:-True }"
      }
    }
  }
}
